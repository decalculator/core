{
    "name": "gui",
    "version": 1.0,
    "usoi": 17,
    "type": "plugin",
    "object_type": "complex",

    "requires":
    {
        "application":
        {
            "minimum_version": "eldest",
            "maximum_version": "latest"
        }
    },

    "register":
    {
        "files":
        {
            "entry":
            {
                "path": "sources/core/plugins/gui/entry.py"
            }
        },

        "methods":
        {
            "entry":
            {
                "file": "entry",
                "mode": "async",
                "type": "complex"
            }
        },

        "execution":
        {
            "execution":
            {
                "mode": "exec",
                "content": "entry",
                "type": "python"
            }
        }
    }
}